# WorldMonitor Production Environment Variables
# Copy this file to .env.production and fill in your values

# ============================================
# DATABASE (Neon Postgres)
# ============================================
DATABASE_URL=postgresql://user:password@your-neon-db.neon.tech/worldmonitor?sslmode=require
DIRECT_URL=postgresql://user:password@your-neon-db.neon.tech/worldmonitor?sslmode=require

# ============================================
# AUTHENTICATION
# ============================================
NEXTAUTH_URL=https://worldmonitor.app
NEXTAUTH_SECRET=your-nextauth-secret-here-generate-with-openssl-rand-base64-32

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ============================================
# PAYMENT (Stripe)
# ============================================
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs
STRIPE_PRICE_ID_PRO=price_your_pro_price_id
STRIPE_PRICE_ID_ENTERPRISE=price_your_enterprise_price_id

# ============================================
# EMAIL (Resend or SendGrid)
# ============================================
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@worldmonitor.app

# ============================================
# REDIS (Upstash for caching)
# ============================================
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ============================================
# API KEYS (from existing .env.example)
# ============================================
# LLM Providers
GROQ_API_KEY=your-groq-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
OLLAMA_ENDPOINT=http://localhost:11434

# Data Sources
OPENWEATHER_API_KEY=your-openweather-key
POLYMARKET_API_KEY=your-polymarket-key
COINGECKO_API_KEY=your-coingecko-key

# ============================================
# MONITORING & ANALYTICS
# ============================================
SENTRY_DSN=your-sentry-dsn
VERCEL_ANALYTICS_ID=your-vercel-analytics-id

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_PAID_FEATURES=true
ENABLE_CUSTOM_DOMAINS=true
ENABLE_API_ACCESS=true
ENABLE_WEBHOOKS=true

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_FREE_TIER=100
RATE_LIMIT_PRO_TIER=1000
RATE_LIMIT_ENTERPRISE_TIER=10000

# ============================================
# STORAGE (for user uploads, optional)
# ============================================
S3_BUCKET_NAME=worldmonitor-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-s3-access-key
S3_SECRET_ACCESS_KEY=your-s3-secret-key

# ============================================
# WEBHOOKS & INTEGRATIONS
# ============================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK

# ============================================
# SECURITY
# ============================================
ALLOWED_ORIGINS=https://worldmonitor.app,https://tech.worldmonitor.app,https://finance.worldmonitor.app,https://happy.worldmonitor.app
JWT_SECRET=your-jwt-secret-here
ENCRYPTION_KEY=your-encryption-key-32-chars

# ============================================
# DEMO MODE
# ============================================
DEMO_MODE_ENABLED=true
DEMO_SESSION_DURATION=3600
